# Environment (development, testing, production)
ENVIRONMENT=development
LOG_LEVEL=info
# PORT is provided automatically by Railway in production; default for local.
PORT=8000

# CORS allowed origins — comma-separated, or "*" for all.
# Production: set explicit origins (e.g. https://app.calry.ai) to allow credentials.
ALLOWED_ORIGINS=*

# Database
# Use postgresql+asyncpg:// for async connections.
# On Railway, reference the Postgres plugin var: DATABASE_URL=${{Postgres.DATABASE_URL}}
# (the app auto-rewrites postgres:// and postgresql:// to the async driver).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/calry

# Firebase Auth Configuration
FIREBASE_PROJECT_ID=calry-62362
# Full Firebase service account JSON. In Railway, paste the full JSON as the variable value.
FIREBASE_CREDENTIALS=

# AI Provider API Keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Selected AI Provider
DEFAULT_AI_PROVIDER=openrouter
AI_PROVIDER=openrouter

# OpenRouter specific models
OPENROUTER_TEXT_MODEL=google/gemini-2.5-flash
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash
OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash

# Retries and timeouts
AI_REQUEST_TIMEOUT_SECONDS=30.0
AI_MAX_RETRIES=1
